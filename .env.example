# ============================================================
# LOKÁLNÍ VÝVOJ: zkopíruj jako .env a vyplň hodnoty
# RAILWAY: tyto proměnné nastav v Settings → Variables
#          .env soubor Railway NEČTE — pouze dashboard!
# ============================================================

# POVINNÉ — tokeny po rozdělení na ArionDND + ArionBOT
DISCORD_TOKEN_DND=sem_vloz_token_ariondnd
DISCORD_TOKEN_BOT=sem_vloz_token_arionbot
# Starý token (pro main.py — zachován pro zpětnou kompatibilitu)
DISCORD_TOKEN=sem_vloz_svuj_discord_bot_token
# DATA — Railway: nastav na /data a přidej Persistent Volume
# Lokálně: nechat prázdné (použije se src/database/data/)
DATA_DIR=/data

# VOLITELNÉ (mají výchozí hodnoty)
PREFIX=!
WIKI_URL=https://tvowiki.cz/aurionis
EMBED_COLOR=FFD700
CAMPFIRE_CHANNEL=campfire
