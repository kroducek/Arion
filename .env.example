# Zkopíruj jako .env pro lokální vývoj
# Na Railway nastav tyto proměnné v Settings → Variables

# POVINNÉ
DISCORD_TOKEN=tvuj_discord_bot_token

# DATA (Railway: nastav na /data a přidej persistent volume)
DATA_DIR=/data

# VOLITELNÉ (mají výchozí hodnoty)
PREFIX=!
WIKI_URL=https://tvowiki.cz/aurionis
EMBED_COLOR=FFD700
CAMPFIRE_CHANNEL=campfire
